{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "qemu-start-gdb",
            "type": "shell",
            "command": "qemu-system-m68k",
            "args": [
                "-M", "virt",
                "-cpu", "m68020",
                "-kernel", "m68k-monitor.elf",
                "-display", "none",
                "-s", "-S"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "isBackground": true,
            "problemMatcher": [],
            "presentation": {
                "reveal": "silent",
                "panel": "shared"
            }
        },
        {
            "label": "qemu-stop",
            "type": "shell",
            "command": "pkill",
            "args": ["-f", "qemu-system-m68k.*m68k-monitor.elf"],
            "problemMatcher": [],
            "presentation": {
                "reveal": "silent"
            }
        },
        {
            "label": "build-qemu",
            "type": "shell",
            "command": "make",
            "args": ["all", "VARIANT=qemu"],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": ["$gcc"]
        },
        {
            "label": "build-realhw",
            "type": "shell",
            "command": "make",
            "args": ["all", "VARIANT=realhw"],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": ["$gcc"]
        }
    ]
}
