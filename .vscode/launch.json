{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "QEMU: Debug m68k-monitor",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/m68k-monitor.elf",
            "cwd": "${workspaceFolder}",
            "MIMode": "gdb",
            "miDebuggerPath": "/opt/toolchain-m68k-elf-current/bin/m68k-elf-gdb",
            "miDebuggerServerAddress": "localhost:1234",
            "stopAtEntry": true,
            "externalConsole": false,
            "preLaunchTask": "qemu-start-gdb",
            "postDebugTask": "qemu-stop",
            "setupCommands": [
                {
                    "text": "set architecture m68k:68020"
                },
                {
                    "text": "break __start"
                }
            ]
        },
        {
            "name": "QEMU: Attach to running GDB server",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/m68k-monitor.elf",
            "cwd": "${workspaceFolder}",
            "MIMode": "gdb",
            "miDebuggerPath": "/opt/toolchain-m68k-elf-current/bin/m68k-elf-gdb",
            "miDebuggerServerAddress": "localhost:1234",
            "stopAtEntry": false,
            "externalConsole": false,
            "setupCommands": [
                {
                    "text": "set architecture m68k:68020"
                }
            ]
        }
    ]
}
